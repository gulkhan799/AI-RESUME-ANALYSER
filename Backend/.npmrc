# Puppeteer normally tries to download its own bundled Chromium build during
# `npm install`. On some Windows machines (corporate proxies, antivirus
# interference, partial/corrupted cache entries, etc.) that download fails
# and crashes the whole `npm install`, as happened here:
#   "Failed to set up chrome v148.0.7778.97!"
#
# Since src/services/ai.service.js already knows how to fall back to a
# locally installed Chrome/Brave/Edge browser (see findBrowserExecutable),
# we don't need Puppeteer's bundled download at all. Skipping it makes
# `npm install` fast and reliable on every machine.
puppeteer_skip_download=true
